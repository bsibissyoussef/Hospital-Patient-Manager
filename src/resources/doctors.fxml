<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.DoctorController"
      styleClass="main-content" spacing="16"
      style="-fx-padding: 20;">

    <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="16">
        <Label text="👨‍⚕️ Gestion des Médecins" styleClass="page-title"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelStatus" text="Page Médecins" styleClass="status-label"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- FORMULAIRE AVEC SCROLL -->
        <ScrollPane fitToWidth="true" prefWidth="340"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;
                           -fx-border-color: transparent;">
            <VBox styleClass="form-card" prefWidth="320" spacing="12">

                <Label text="➕ Nouveau Médecin" styleClass="card-title"/>

                <Label text="Nom complet" styleClass="field-label"/>
                <TextField fx:id="fieldDoctorName"
                           promptText="Ex: Dr. Martin"
                           styleClass="input-field"/>

                <Label text="Spécialisation" styleClass="field-label"/>
                <TextField fx:id="fieldSpecialization"
                           promptText="Ex: Cardiologie"
                           styleClass="input-field"/>

                <Label text="Téléphone" styleClass="field-label"/>
                <TextField fx:id="fieldPhone"
                           promptText="Ex: 0612345678"
                           styleClass="input-field"/>

                <VBox spacing="8" styleClass="button-group">
                    <Button text="➕ Ajouter" onAction="#handleAddDoctor"
                            styleClass="btn-add" maxWidth="Infinity"/>
                    <Button text="✏️ Modifier" onAction="#handleUpdateDoctor"
                            styleClass="btn-update" maxWidth="Infinity"/>
                    <Button text="🗑️ Supprimer" onAction="#handleDeleteDoctor"
                            styleClass="btn-delete" maxWidth="Infinity"/>
                    <Button text="🔄 Effacer" onAction="#handleClearDoctor"
                            styleClass="btn-clear" maxWidth="Infinity"/>
                </VBox>

            </VBox>
        </ScrollPane>

        <!-- TABLE -->
        <VBox styleClass="table-card" HBox.hgrow="ALWAYS" spacing="12">
            <Label text="📋 Liste des Médecins" styleClass="card-title"/>
            <TableView fx:id="doctorTable"
                       VBox.vgrow="ALWAYS"
                       styleClass="patient-table">
                <columns>
                    <TableColumn fx:id="colDoctorId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colDoctorName" text="Nom" prefWidth="180"/>
                    <TableColumn fx:id="colSpecialization"
                                 text="Spécialisation" prefWidth="180"/>
                    <TableColumn fx:id="colPhone" text="Téléphone" prefWidth="150"/>
                </columns>
                <placeholder>
                    <Label text="Aucun médecin trouvé."
                           styleClass="table-placeholder"/>
                </placeholder>
            </TableView>
        </VBox>

    </HBox>

</VBox>