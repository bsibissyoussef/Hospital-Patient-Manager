<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AppointmentController"
      styleClass="main-content" spacing="16"
      style="-fx-padding: 20;">

    <!-- EN-TETE -->
    <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="16">
        <Label text="📅 Gestion des Rendez-vous" styleClass="page-title"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelStatus" text="Page Rendez-vous" styleClass="status-label"/>
    </HBox>

    <!-- STATISTIQUES -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" alignment="CENTER"
              prefWidth="200" prefHeight="80">
            <Label text="Total Rendez-vous" styleClass="stat-label"/>
            <Label fx:id="labelTotalAppt" text="0" styleClass="stat-number"/>
        </VBox>
        <VBox styleClass="stat-card-green" alignment="CENTER"
              prefWidth="200" prefHeight="80">
            <Label text="Aujourd'hui" styleClass="stat-label"/>
            <Label fx:id="labelTodayAppt" text="0" styleClass="stat-number-green"/>
        </VBox>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- FORMULAIRE AVEC SCROLL -->
        <ScrollPane fitToWidth="true" prefWidth="340"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;
                           -fx-border-color: transparent;">

            <VBox styleClass="form-card" prefWidth="320" spacing="12">

                <Label text="📅 Nouveau Rendez-vous" styleClass="card-title"/>

                <Label text="Patient" styleClass="field-label"/>
                <ComboBox fx:id="comboApptPatient"
                          promptText="Sélectionner un patient"
                          styleClass="combo-field"
                          maxWidth="Infinity"/>

                <Label text="Médecin" styleClass="field-label"/>
                <ComboBox fx:id="comboApptDoctor"
                          promptText="Sélectionner un médecin"
                          styleClass="combo-field"
                          maxWidth="Infinity"/>

                <Label text="Date (JJ/MM/AAAA)" styleClass="field-label"/>
                <TextField fx:id="fieldDate"
                           promptText="Ex: 20/03/2026"
                           styleClass="input-field"/>

                <Label text="Heure (HH:MM)" styleClass="field-label"/>
                <TextField fx:id="fieldTime"
                           promptText="Ex: 09:00"
                           styleClass="input-field"/>

                <VBox spacing="8" styleClass="button-group">
                    <Button text="➕ Planifier"
                            onAction="#handleAddAppointment"
                            styleClass="btn-add"
                            maxWidth="Infinity"/>
                    <Button text="✏️ Modifier"
                            onAction="#handleUpdateAppointment"
                            styleClass="btn-update"
                            maxWidth="Infinity"/>
                    <Button text="🗑️ Supprimer"
                            onAction="#handleDeleteAppointment"
                            styleClass="btn-delete"
                            maxWidth="Infinity"/>
                    <Button text="🔄 Effacer"
                            onAction="#handleClearAppointment"
                            styleClass="btn-clear"
                            maxWidth="Infinity"/>
                </VBox>

            </VBox>
        </ScrollPane>

        <!-- TABLE -->
        <VBox styleClass="table-card" HBox.hgrow="ALWAYS" spacing="12">

            <Label text="📋 Liste des Rendez-vous" styleClass="card-title"/>

            <TableView fx:id="appointmentTable"
                       VBox.vgrow="ALWAYS"
                       styleClass="patient-table">
                <columns>
                    <TableColumn fx:id="colApptId"
                                 text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colApptPatient"
                                 text="Patient" prefWidth="160"/>
                    <TableColumn fx:id="colApptDoctor"
                                 text="Médecin" prefWidth="180"/>
                    <TableColumn fx:id="colApptDate"
                                 text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colApptTime"
                                 text="Heure" prefWidth="80"/>
                </columns>
                <placeholder>
                    <Label text="Aucun rendez-vous trouvé."
                           styleClass="table-placeholder"/>
                </placeholder>
            </TableView>

        </VBox>

    </HBox>

</VBox>